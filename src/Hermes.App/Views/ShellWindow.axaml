<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="Hermes.App.Views.ShellWindow"
        Title="Hermes — Document Intelligence"
        Width="980" Height="660"
        WindowStartupLocation="CenterScreen"
        CanResize="True"
        MinWidth="700" MinHeight="500"
        Background="{DynamicResource ChatBg}">

  <Grid RowDefinitions="*,Auto">

    <!-- ── Main: ActivityBar + Navigator + Splitter + Content ── -->
    <Grid Grid.Row="0" ColumnDefinitions="48,260,4,*">

      <!-- ════════════════════ COLUMN 0: ACTIVITY BAR ════════════════════ -->
      <Border Grid.Column="0"
              Background="{DynamicResource SidebarBg}"
              BorderBrush="{DynamicResource SidebarBorder}"
              BorderThickness="0,0,1,0">
        <DockPanel LastChildFill="False">
          <!-- Top icons -->
          <StackPanel DockPanel.Dock="Top" Spacing="4" Margin="0,8,0,0"
                      HorizontalAlignment="Center">
            <Button x:Name="NavActionItems" Content="📋" FontSize="18"
                    Width="36" Height="36" Padding="0"
                    ToolTip.Tip="Action Items" Classes="activityIcon"
                    Background="Transparent" HorizontalContentAlignment="Center" />
            <Button x:Name="NavDocuments" Content="📁" FontSize="18"
                    Width="36" Height="36" Padding="0"
                    ToolTip.Tip="Documents" Classes="activityIcon"
                    Background="Transparent" HorizontalContentAlignment="Center" />
            <Button x:Name="NavThreads" Content="📧" FontSize="18"
                    Width="36" Height="36" Padding="0"
                    ToolTip.Tip="Email Threads" Classes="activityIcon"
                    Background="Transparent" HorizontalContentAlignment="Center" />
            <Button x:Name="NavTimeline" Content="⏰" FontSize="18"
                    Width="36" Height="36" Padding="0"
                    ToolTip.Tip="Timeline" Classes="activityIcon"
                    Background="Transparent" HorizontalContentAlignment="Center" />
            <Button x:Name="NavActivity" Content="⚡" FontSize="18"
                    Width="36" Height="36" Padding="0"
                    ToolTip.Tip="Activity Log" Classes="activityIcon"
                    Background="Transparent" HorizontalContentAlignment="Center" />
          </StackPanel>
          <!-- Bottom icons -->
          <StackPanel DockPanel.Dock="Bottom" Spacing="4" Margin="0,0,0,8"
                      HorizontalAlignment="Center">
            <Button x:Name="NavSettings" Content="⚙" FontSize="18"
                    Width="36" Height="36" Padding="0"
                    ToolTip.Tip="Settings" Classes="activityIcon"
                    Background="Transparent" HorizontalContentAlignment="Center" />
          </StackPanel>
        </DockPanel>
      </Border>

      <!-- ════════════════════ COLUMN 1: NAVIGATOR PANEL ════════════════════ -->
      <Border Grid.Column="1"
              Background="{DynamicResource SidebarBg}"
              BorderBrush="{DynamicResource SidebarBorder}"
              BorderThickness="0,0,1,0">
        <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                      VerticalScrollBarVisibility="Auto">
          <StackPanel>

            <!-- Navigator heading -->
            <Border Padding="16,14,12,12"
                    BorderBrush="{DynamicResource SidebarBorder}"
                    BorderThickness="0,0,0,1">
              <StackPanel Orientation="Horizontal" Spacing="8">
                <TextBlock Text="⚡" FontSize="15" VerticalAlignment="Center" />
                <TextBlock x:Name="NavigatorTitle" Text="HERMES" FontWeight="Bold" FontSize="13"
                           LetterSpacing="2" VerticalAlignment="Center"
                           Foreground="{DynamicResource PrimaryFg}"
                           FontFamily="Inter,Segoe UI,sans-serif" />
              </StackPanel>
            </Border>

            <!-- ── OLLAMA ── -->
            <Expander Classes="section" IsExpanded="True">
              <Expander.Header>
                <TextBlock Text="OLLAMA" FontSize="10" FontWeight="SemiBold"
                           Foreground="{DynamicResource SectionFg}" LetterSpacing="1.5" />
              </Expander.Header>
              <StackPanel Margin="20,4,12,12" Spacing="6">
                <StackPanel Orientation="Horizontal" Spacing="8">
                  <Ellipse x:Name="OllamaDot" Width="10" Height="10" Fill="#888"
                           VerticalAlignment="Center" />
                  <TextBlock x:Name="OllamaStatusText" Text="Checking…"
                             FontSize="12" Foreground="{DynamicResource MutedFg}"
                             VerticalAlignment="Center" />
                </StackPanel>
                <TextBlock x:Name="OllamaModelsText" Text="" FontSize="11"
                           Foreground="{DynamicResource MutedFg}" TextWrapping="Wrap" />
              </StackPanel>
            </Expander>

            <Rectangle Height="1" Fill="{DynamicResource SidebarBorder}" />

            <!-- ── INDEX ── -->
            <Expander Classes="section" IsExpanded="True">
              <Expander.Header>
                <TextBlock Text="INDEX" FontSize="10" FontWeight="SemiBold"
                           Foreground="{DynamicResource SectionFg}" LetterSpacing="1.5" />
              </Expander.Header>
              <StackPanel Margin="20,4,12,12" Spacing="5">
                <TextBlock x:Name="IndexDocCount" Text="0 documents" FontSize="12"
                           Foreground="{DynamicResource PrimaryFg}" />
                <Grid RowDefinitions="Auto,Auto" Margin="0,3,0,0">
                  <Grid Grid.Row="0" ColumnDefinitions="*,Auto" Margin="0,0,0,2">
                    <TextBlock Text="Extracted" FontSize="10"
                               Foreground="{DynamicResource MutedFg}" VerticalAlignment="Center" />
                    <TextBlock Grid.Column="1" x:Name="ExtractedCount" Text="0" FontSize="10"
                               Foreground="{DynamicResource MutedFg}" VerticalAlignment="Center" />
                  </Grid>
                  <ProgressBar Grid.Row="1" x:Name="ExtractedBar" Minimum="0" Maximum="100" Value="0"
                               Height="4" CornerRadius="2" HorizontalAlignment="Stretch" />
                </Grid>
                <Grid RowDefinitions="Auto,Auto">
                  <Grid Grid.Row="0" ColumnDefinitions="*,Auto" Margin="0,0,0,2">
                    <TextBlock Text="Embedded" FontSize="10"
                               Foreground="{DynamicResource MutedFg}" VerticalAlignment="Center" />
                    <TextBlock Grid.Column="1" x:Name="EmbeddedCount" Text="0" FontSize="10"
                               Foreground="{DynamicResource MutedFg}" VerticalAlignment="Center" />
                  </Grid>
                  <ProgressBar Grid.Row="1" x:Name="EmbeddedBar" Minimum="0" Maximum="100" Value="0"
                               Height="4" CornerRadius="2" HorizontalAlignment="Stretch" />
                </Grid>
                <!-- Category breakdown (monospace, compact) -->
                <TextBlock x:Name="CategoryText" Text="" FontSize="10"
                           Foreground="{DynamicResource MutedFg}"
                           FontFamily="Cascadia Code,Consolas,monospace"
                           TextWrapping="Wrap" Margin="0,4,0,0" />
              </StackPanel>
            </Expander>

            <Rectangle Height="1" Fill="{DynamicResource SidebarBorder}" />

            <!-- ── EMAIL ACCOUNTS ── -->
            <Expander Classes="section" IsExpanded="True">
              <Expander.Header>
                <TextBlock Text="EMAIL ACCOUNTS" FontSize="10" FontWeight="SemiBold"
                           Foreground="{DynamicResource SectionFg}" LetterSpacing="1.5" />
              </Expander.Header>
              <StackPanel Margin="20,4,12,12" Spacing="6">
                <TextBlock x:Name="AccountsText" Text="No accounts configured."
                           FontSize="11" Foreground="{DynamicResource MutedFg}" TextWrapping="Wrap" />
                <Button x:Name="AddAccountButton" Content="+ Add Account"
                        Classes="action" HorizontalAlignment="Left" />
              </StackPanel>
            </Expander>

            <Rectangle Height="1" Fill="{DynamicResource SidebarBorder}" />

            <!-- ── WATCH FOLDERS ── -->
            <Expander Classes="section" IsExpanded="True">
              <Expander.Header>
                <TextBlock Text="WATCH FOLDERS" FontSize="10" FontWeight="SemiBold"
                           Foreground="{DynamicResource SectionFg}" LetterSpacing="1.5" />
              </Expander.Header>
              <StackPanel Margin="20,4,12,12" Spacing="6">
                <TextBlock x:Name="WatchFoldersText" Text="None configured."
                           FontSize="11" Foreground="{DynamicResource MutedFg}" TextWrapping="Wrap" />
                <Button x:Name="AddWatchFolderButton" Content="+ Add Folder"
                        Classes="action" HorizontalAlignment="Left" />
              </StackPanel>
            </Expander>

            <Rectangle Height="1" Fill="{DynamicResource SidebarBorder}" />

            <!-- ── Sync controls ── -->
            <StackPanel Margin="16,10,12,14" Spacing="8">
              <TextBlock x:Name="LastSyncText" Text="Last sync: —" FontSize="10"
                         Foreground="{DynamicResource MutedFg}" />
              <StackPanel Orientation="Horizontal" Spacing="6">
                <Button x:Name="SyncNowButton" Content="⟳ Sync Now" Classes="action" />
                <Button x:Name="PauseButton"   Content="⏸ Pause"    Classes="action" />
                <Button x:Name="SettingsButton" Content="⚙"         Classes="action" Padding="7,3" />
              </StackPanel>
            </StackPanel>

          </StackPanel>
        </ScrollViewer>
      </Border>

      <!-- ════════════════════ COLUMN 2: SPLITTER ════════════════════ -->
      <GridSplitter Grid.Column="2"
                    Background="{DynamicResource SidebarBorder}"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch" />

      <!-- ════════════════════ COLUMN 3: CONTENT AREA ════════════════════ -->
      <Grid Grid.Column="3" RowDefinitions="Auto,*,Auto" Background="{DynamicResource ChatBg}">

        <!-- Tab toggle bar -->
        <Border Grid.Row="0" BorderBrush="{DynamicResource SidebarBorder}" BorderThickness="0,0,0,1" Padding="12,6">
          <StackPanel Orientation="Horizontal" Spacing="4">
            <ToggleButton x:Name="ChatTabButton" Content="💬 Chat" IsChecked="True"
                          FontSize="12" Padding="10,4" CornerRadius="4" />
            <ToggleButton x:Name="TodoTabButton" Content="📋 Action Items"
                          FontSize="12" Padding="10,4" CornerRadius="4" />
          </StackPanel>
        </Border>

        <!-- Chat view -->
        <ScrollViewer x:Name="ChatScroller" Grid.Row="1" Padding="0,8">
          <StackPanel x:Name="ChatPanel" Margin="20,8" Spacing="12" />
        </ScrollViewer>

        <!-- TODO / Action Items view (hidden by default) -->
        <ScrollViewer x:Name="TodoScroller" Grid.Row="1" Padding="0,8" IsVisible="False">
          <StackPanel x:Name="TodoPanel" Margin="20,8" Spacing="12" />
        </ScrollViewer>

        <!-- Input bar -->
        <Border Grid.Row="2"
                Background="{DynamicResource ChatBg}"
                BorderBrush="{DynamicResource SidebarBorder}"
                BorderThickness="0,1,0,0"
                Padding="16,10">
          <StackPanel Spacing="8">

            <!-- Suggested query chips (hidden once first message sent) -->
            <WrapPanel x:Name="SuggestedQueries" Orientation="Horizontal" IsVisible="True">
              <Button Content="recent invoices"    Classes="chip" Margin="0,0,6,6" />
              <Button Content="bank statements"    Classes="chip" Margin="0,0,6,6" />
              <Button Content="tax documents"      Classes="chip" Margin="0,0,6,6" />
              <Button Content="insurance policies" Classes="chip" Margin="0,0,6,6" />
              <Button Content="list all documents" Classes="chip" Margin="0,0,6,6" />
            </WrapPanel>

            <Grid ColumnDefinitions="*,Auto,Auto">
              <TextBox x:Name="ChatInput" Grid.Column="0"
                       Watermark="Ask Hermes… (e.g. 'find my car insurance documents')"
                       FontSize="13" Padding="10,7" CornerRadius="6" />
              <ToggleButton x:Name="AiToggle" Grid.Column="1"
                            Content="AI" ToolTip.Tip="Toggle AI-enhanced answers (uses Ollama)"
                            FontSize="12" Padding="10,6" Margin="6,0,0,0" />
              <Button x:Name="SendButton" Grid.Column="2"
                      Content="→" FontSize="15" FontWeight="Bold"
                      Padding="12,6" Margin="6,0,0,0"
                      Background="{DynamicResource AccentBrush}"
                      Foreground="White"
                      CornerRadius="6" />
            </Grid>

          </StackPanel>
        </Border>

      </Grid>

    </Grid>

    <!-- ════════════════════ STATUS BAR ════════════════════ -->
    <Border Grid.Row="1"
            Background="{DynamicResource SidebarBg}"
            BorderBrush="{DynamicResource SidebarBorder}"
            BorderThickness="0,1,0,0"
            Padding="14,5">
      <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
        <Ellipse x:Name="StatusDot" Width="8" Height="8" Fill="#4CAF50"
                 VerticalAlignment="Center" />
        <TextBlock x:Name="StatusBarText" Text="Starting…" FontSize="11"
                   Foreground="{DynamicResource MutedFg}" VerticalAlignment="Center" />
      </StackPanel>
    </Border>

  </Grid>

</Window>
