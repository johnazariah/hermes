<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="Hermes.App.Views.ShellWindow"
        Title="Hermes — Document Intelligence"
        Width="960" Height="640"
        WindowStartupLocation="CenterScreen"
        CanResize="True"
        MinWidth="800" MinHeight="500">

  <Grid ColumnDefinitions="280,*">

    <!-- ═══ LEFT PANEL: Status ═══ -->
    <Border Grid.Column="0" BorderBrush="#30808080" BorderThickness="0,0,1,0" Background="#08000000">
      <ScrollViewer>
        <StackPanel Margin="12" Spacing="14">

          <!-- Ollama -->
          <StackPanel Spacing="2">
            <TextBlock Text="🤖 Ollama" FontWeight="Bold" FontSize="13" />
            <TextBlock x:Name="OllamaStatus" Text="Checking..." FontSize="12" Foreground="#888" />
            <TextBlock x:Name="OllamaModels" Text="" FontSize="11" Foreground="#666" FontFamily="Cascadia Mono,Consolas,monospace" />
          </StackPanel>

          <Separator Height="1" />

          <!-- Index -->
          <StackPanel Spacing="2">
            <TextBlock Text="📚 Index" FontWeight="Bold" FontSize="13" />
            <TextBlock x:Name="IndexStats" Text="Loading..." FontSize="12" Foreground="#888" />
            <TextBlock x:Name="CategorySummary" Text="" FontSize="11" Foreground="#666" FontFamily="Cascadia Mono,Consolas,monospace" />
          </StackPanel>

          <Separator Height="1" />

          <!-- Email Accounts -->
          <StackPanel Spacing="2">
            <TextBlock Text="📧 Accounts" FontWeight="Bold" FontSize="13" />
            <TextBlock x:Name="AccountsList" Text="Loading..." FontSize="11" Foreground="#666" FontFamily="Cascadia Mono,Consolas,monospace" />
            <Button x:Name="AddAccountButton" Content="+ Add Account" FontSize="11" Padding="6,2" HorizontalAlignment="Left" Margin="0,2,0,0" />
          </StackPanel>

          <Separator Height="1" />

          <!-- Watch Folders -->
          <StackPanel Spacing="2">
            <TextBlock Text="📁 Watch Folders" FontWeight="Bold" FontSize="13" />
            <TextBlock x:Name="WatchFoldersList" Text="None configured." FontSize="11" Foreground="#666" />
            <Button x:Name="AddWatchFolderButton" Content="+ Add Folder" FontSize="11" Padding="6,2" HorizontalAlignment="Left" Margin="0,2,0,0" />
          </StackPanel>

          <Separator Height="1" />

          <!-- Controls -->
          <StackPanel Spacing="4">
            <TextBlock x:Name="LastSyncText" Text="Last sync: —" FontSize="11" Foreground="#888" />
            <StackPanel Orientation="Horizontal" Spacing="8">
              <Button x:Name="SyncNowButton" Content="⟳ Sync Now" FontSize="11" Padding="8,4" />
              <Button x:Name="PauseButton" Content="⏸ Pause" FontSize="11" Padding="8,4" />
              <Button x:Name="SettingsButton" Content="⚙" FontSize="11" Padding="8,4" />
            </StackPanel>
          </StackPanel>

        </StackPanel>
      </ScrollViewer>
    </Border>

    <!-- ═══ RIGHT PANEL: Chat ═══ -->
    <Grid Grid.Column="1" RowDefinitions="*,Auto">

      <!-- Chat history -->
      <ScrollViewer x:Name="ChatScroller" Grid.Row="0" Margin="0">
        <StackPanel x:Name="ChatPanel" Margin="16,12" Spacing="12" />
      </ScrollViewer>

      <!-- Input bar -->
      <Border Grid.Row="1" BorderBrush="#30808080" BorderThickness="0,1,0,0" Padding="12,8">
        <Grid ColumnDefinitions="*,Auto,Auto">
          <TextBox x:Name="ChatInput" Grid.Column="0"
                   Watermark="Ask Hermes... (e.g. 'find my car insurance documents')"
                   FontSize="13" Padding="8,6" />
          <ToggleButton x:Name="AiToggle" Grid.Column="1"
                        Content="🧠" ToolTip.Tip="Toggle AI-enhanced answers (uses Ollama)"
                        FontSize="14" Padding="6,4" Margin="6,0,0,0" />
          <Button x:Name="SendButton" Grid.Column="2"
                  Content="🔍" FontSize="14" Padding="8,4" Margin="4,0,0,0" />
        </Grid>
      </Border>

    </Grid>

  </Grid>

</Window>
