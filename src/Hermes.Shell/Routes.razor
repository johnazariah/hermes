<Router AppAssembly="typeof(Hermes.UI.Routes).Assembly">
    <Found Context="routeData">
        <RouteView RouteData="routeData" DefaultLayout="typeof(Hermes.UI.Layout.MainLayout)" />
    </Found>
    <NotFound>
        <LayoutView Layout="typeof(Hermes.UI.Layout.MainLayout)">
            <div class="text-center py-20">
                <h1 class="text-2xl font-bold text-neutral-400">Page not found</h1>
            </div>
        </LayoutView>
    </NotFound>
</Router>
